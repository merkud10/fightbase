    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:start:pg": "docker compose -f docker-compose.postgres.yml up -d",
    "db:stop:pg": "docker compose -f docker-compose.postgres.yml down",
    "scheduler": "node scripts/local-scheduler.js",
    "content:localize": "node scripts/localize-existing-content.js",
