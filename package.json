    "content:repair-ufc-local-slugs": "node scripts/repair-ufc-local-slugs.js",
    "content:reconcile-ufc-fighters": "node scripts/reconcile-ufc-fighters.js",
    "content:cleanup-ufc-history": "node scripts/cleanup-ufc-fight-history.js",
    "content:audit-russian-fighter-names": "node scripts/audit-russian-fighter-names.js",
    "content:backfill-fighter-bio-en": "node scripts/backfill-fighter-bio-en.js",
    "content:fill-missing-fighter-bio-en": "node scripts/fill-missing-fighter-bio-en.js",
    "content:refresh-fighter-bio-ru-quality": "node scripts/refresh-fighter-bio-ru-quality.js",
    "content:refresh-fighter-bio-en-quality": "node scripts/refresh-fighter-bio-en-quality.js",
