  "dependencies": {
    "@prisma/client": "6.18.0",
    "dotenv": "^17.3.1",
    "next": "15.5.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.14.0",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "prisma": "6.18.0",
    "tsx": "^4.21.0",
    "typescript": "5.8.3"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
