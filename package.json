    "prisma:generate:pg": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:push": "prisma db push",
    "db:push:pg": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:migrate": "prisma migrate dev",
