    "jobs:process": "node scripts/process-background-jobs.js",
    "jobs:loop": "node scripts/process-background-jobs-loop.js",
    "jobs:trigger": "node scripts/trigger-background-jobs.js",
    "content:refresh-fighters-full": "node scripts/seed-fighter-cards.js && node scripts/sync-ufc-roster.js && node scripts/sync-ufc-russian-names.js --concurrency 24 && node scripts/enrich-fighter-profiles.js && node scripts/normalize-fighter-profiles.js && node scripts/normalize-imported-fighters.js && node scripts/backfill-fighter-bio-en.js && node scripts/fill-missing-fighter-bio-en.js && node scripts/refresh-fighter-bio-en-quality.js && node scripts/refresh-fighter-bio-ru-quality.js && node scripts/fill-missing-fighter-photos.js",
    "ingest:feed": "node scripts/ingest-feed.js",
    "ingest:smoke": "node scripts/ingest-feed.js --file ingestion/smoke-published-news.json",
    "ingest:fetch": "node scripts/fetch-source-feed.js",
    "ingest:cron": "node scripts/trigger-ingest-cron.js",
    "ingest:analysis-cron": "node scripts/trigger-ingest-cron.js --job weekly-analysis"
