{
  "name": "fightbase-media",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "clean": "node scripts/clean-next.js",
    "build": "next build",
    "start": "node scripts/start-standalone.js",
    "lint": "next lint",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:smoke": "tsx tests/smoke-app.ts",
    "typecheck": "npm exec next typegen . && tsc --noEmit",
